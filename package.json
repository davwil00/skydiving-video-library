{
  "name": "skydiving-video-library-v2",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "react-router typegen && eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts",
    "migrate-dev": "prisma generate && prisma migrate dev",
    "migrate-deploy": "prisma generate && prisma migrate deploy",
    "typecheck": "react-router typegen && tsc",
    "typegen": "react-router typegen",
    "test": "dotenv -e .env.test -- npx prisma migrate deploy && vitest --run",
    "start": "react-router-serve ./build/server/index.js",
    "generate": "prisma generate",
    "icons": "rimraf app/components/formations/8-way && npx @svgr/cli --out-dir app/components/formations/8-way -- public/images/8-way",
    "icons:watch": "npm-watch icons",
    "dev:svg": "run-s icons icons:watch"
  },
  "watch": {
    "icons": {
      "patterns": [
        "icons"
      ]
    },
    "extensions": "svg",
    "quiet": false
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@react-router/fs-routes": "^7.9.4",
    "@react-router/node": "^7.9.4",
    "@react-router/serve": "^7.9.4",
    "@tailwindcss/vite": "^4.1.14",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^10.0.0",
    "ffmetadata": "^1.7.0",
    "isbot": "^5.1.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.12.0",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.9.4",
    "@svgr/cli": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "autoprefixer": "^10.4.20",
    "daisyui": "^5.2.3",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.13.0",
    "postcss": "^8.5.6",
    "prisma": "^6.17.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^5.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

{
  "name": "skydiving-video-library-v2",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "react-router typegen && npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check . --write",
    "format:fix": "npx @biomejs/biome format . --write",
    "setup": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts",
    "migrate-dev": "prisma generate && prisma migrate dev",
    "migrate-deploy": "prisma generate && prisma migrate deploy",
    "typecheck": "react-router typegen && tsc",
    "typegen": "react-router typegen",
    "test": "dotenv -e .env.test -- npx prisma migrate deploy && vitest --run",
    "start": "react-router-serve ./build/server/index.js",
    "generate": "prisma generate",
    "icons": "rimraf app/components/formations/8-way && npx @svgr/cli --out-dir app/components/formations/8-way -- public/images/8-way",
    "icons:watch": "npm-watch icons",
    "dev:svg": "run-s icons icons:watch"
  },
  "watch": {
    "icons": {
      "patterns": [
        "icons"
      ]
    },
    "extensions": "svg",
    "quiet": false
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^10.0.0",
    "ffmetadata": "^1.7.0",
    "isbot": "^5.1.37",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@react-router/dev": "^7.14.0",
    "@svgr/cli": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.5.19",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.13.0",
    "prisma": "^7.7.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
